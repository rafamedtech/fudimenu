{
  "name": "fudimenu",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "NODE_OPTIONS='--max-http-header-size=32768' next dev --hostname 127.0.0.1",
    "analyze": "ANALYZE=true next build",
    "build": "prisma migrate deploy && next build",
    "start": "next start",
    "lint": "eslint . --max-warnings=0",
    "typecheck": "tsc --noEmit",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate deploy",
    "db:migrate:dev": "prisma migrate dev",
    "db:push": "prisma db push",
    "db:seed": "node --experimental-strip-types prisma/seed.ts",
    "db:seed:marenca": "node --experimental-strip-types prisma/seed-marenca.ts",
    "db:studio": "prisma studio",
    "test": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:local": "node scripts/e2e-local.mjs"
  },
  "prisma": {
    "seed": "node --experimental-strip-types prisma/seed.ts"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@hookform/resolvers": "^3.9.0",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@sentry/nextjs": "^10",
    "@supabase/ssr": "^0.5.1",
    "@supabase/supabase-js": "^2.45.4",
    "@t3-oss/env-nextjs": "^0.11.1",
    "@upstash/ratelimit": "^2.0.3",
    "@upstash/redis": "^1.34.3",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.1",
    "dexie": "^4.4.2",
    "lucide-react": "^0.451.0",
    "next": "^15.5.15",
    "next-intl": "^3.20.0",
    "pg": "^8.20.0",
    "posthog-js": "^1.165.0",
    "posthog-node": "^4.2.0",
    "qrcode": "^1.5.4",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-hook-form": "^7.53.0",
    "sonner": "^1.5.0",
    "stripe": "^17.1.0",
    "tailwind-merge": "^2.5.3",
    "ua-parser-js": "^2.0.9",
    "vaul": "^1.0.0",
    "zod": "^3.23.8",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@next/bundle-analyzer": "^15.5.19",
    "@playwright/test": "^1.48.0",
    "@types/node": "^22.7.4",
    "@types/pg": "^8.20.0",
    "@types/qrcode": "^1.5.5",
    "@types/react": "^19.2.16",
    "@types/react-dom": "^19.2.3",
    "@types/ua-parser-js": "^0.7.39",
    "autoprefixer": "^10.4.20",
    "dotenv": "^17.4.2",
    "eslint": "^9.12.0",
    "eslint-config-next": "^15.5.15",
    "eslint-plugin-fudimenu": "file:./eslint-rules",
    "eslint-plugin-react-hooks": "^5.2.0",
    "postcss": "^8.4.47",
    "prisma": "^7.8.0",
    "tailwindcss": "^3.4.13",
    "typescript": "^5.6.2",
    "vitest": "^2.1.2"
  }
}
