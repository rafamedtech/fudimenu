# Supabase
# Runtime database connection used by Prisma Client in the app.
# Use the pooled/Supavisor URL in production when available.
DATABASE_URL="postgresql://USER:PASSWORD@HOST:6543/postgres?pgbouncer=true"

# Direct database connection used by Prisma CLI for migrations.
# Use the non-pooled Supabase direct URL; do not use pgbouncer here.
DIRECT_URL="postgresql://USER:PASSWORD@HOST:5432/postgres"

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
# Google OAuth — configure in Supabase dashboard under Auth > Providers, not here
# SUPABASE_AUTH_EXTERNAL_GOOGLE_CLIENT_ID=
# SUPABASE_AUTH_EXTERNAL_GOOGLE_SECRET=

# Cloudinary — signed upload (server-side only, no upload preset needed)
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
# Price ID used for the 14-day Pro trial (billing.service.ts → startProTrialForTenant)
STRIPE_PRICE_PRO=
# Price IDs for card subscriptions — monthly and annual (billing.actions.ts → getPriceId)
STRIPE_PRICE_PRO_MONTHLY=
STRIPE_PRICE_PRO_ANNUAL=
STRIPE_PRICE_BUSINESS_MONTHLY=
STRIPE_PRICE_BUSINESS_ANNUAL=

# Resend
RESEND_API_KEY=

# PostHog
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# Sentry
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=

# Upstash (rate limit)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Protects /api/cron/* endpoints — set a long random secret in production
CRON_SECRET=
# true = use mock data (no DB needed); false = use real Supabase Postgres
USE_MOCKS=true
